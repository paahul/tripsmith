# Anthropic (Claude API) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenWeather (free tier) — https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Unsplash (free tier) — https://unsplash.com/developers
# For destination hero images. App degrades gracefully with a gradient if missing.
UNSPLASH_ACCESS_KEY=

# Resend (free tier, 100/day) — https://resend.com
# For the "email this trip" feature on /trip
RESEND_API_KEY=
# Optional override. Defaults to "tripsmith <onboarding@resend.dev>" which works
# without DNS setup. With a verified domain, set e.g. "tripsmith <hi@yourdomain.com>".
EMAIL_FROM=

# Supabase — stores generated trip plans + handles auth. Create a project at
# https://supabase.com, then:
#   1. Settings → Data API: copy the Project URL into NEXT_PUBLIC_SUPABASE_URL.
#   2. Settings → API Keys:
#      - Copy the publishable (anon) key into NEXT_PUBLIC_SUPABASE_ANON_KEY.
#      - Copy the secret (service_role) key into SUPABASE_SERVICE_ROLE_KEY.
#        Server-only secret — never expose this in client code.
#   3. SQL Editor: run the migrations under supabase/migrations/.
# Without these set, the app falls back to in-memory storage and disables
# auth-related features.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
